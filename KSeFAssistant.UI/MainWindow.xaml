<Window
    x:Class="KSeFAssistant.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:KSeFAssistant.UI.Views"
>

    <Grid>
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="false"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="NavInvoices"
                    Content="Faktury"
                    Icon="List"
                    Tag="invoices"/>
                <NavigationViewItem
                    x:Name="NavSettings"
                    Content="Ustawienia"
                    Icon="Setting"
                    Tag="settings"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="O aplikacji"
                    Icon="Help"
                    Tag="about"/>
            </NavigationView.FooterMenuItems>

            <!-- Treść strony -->
            <Frame x:Name="ContentFrame" Margin="0"/>
        </NavigationView>
    </Grid>
</Window>

<ContentDialog
    x:Class="KSeFAssistant.UI.Views.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:KSeFAssistant.UI.ViewModels"
    Title="Eksport faktur"
    PrimaryButtonText="Eksportuj"
    CloseButtonText="Anuluj"
    DefaultButton="Primary"
    MinWidth="480">

    <StackPanel Spacing="16" Padding="8,0">

        <!-- Liczba faktur -->
        <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                 x:Name="InvoiceCountBar"/>

        <!-- PDF folder -->
        <TextBlock Text="Folder docelowy dla plików PDF"
                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     IsReadOnly="True"
                     Text="{x:Bind ViewModel.PdfOutputFolder, Mode=OneWay}"/>
            <Button Grid.Column="1"
                    Content="Przeglądaj..."
                    Click="BrowsePdfFolder_Click"/>
        </Grid>

        <!-- Excel -->
        <CheckBox Content="Generuj raport Excel (.xlsx)"
                  IsChecked="{x:Bind ViewModel.GenerateExcel, Mode=TwoWay}"/>

        <StackPanel Visibility="{x:Bind ViewModel.GenerateExcel, Mode=OneWay,
                    Converter={StaticResource BoolToVisibility}}" Spacing="8">
            <TextBlock Text="Ścieżka pliku Excel"
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" IsReadOnly="True"
                         Text="{x:Bind ViewModel.ExcelOutputPath, Mode=OneWay}"/>
                <Button Grid.Column="1" Content="Przeglądaj..."
                        Click="BrowseExcelPath_Click"/>
            </Grid>
        </StackPanel>

        <!-- Progress -->
        <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                     Maximum="{x:Bind ViewModel.ProgressMax, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay,
                                Converter={StaticResource StringToVisibility}}"
                   TextWrapping="Wrap"/>

    </StackPanel>
</ContentDialog>

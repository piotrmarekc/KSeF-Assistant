<Page
    x:Class="KSeFAssistant.UI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="480">
        <TextBlock Text="KSeF Assistant" Style="{StaticResource TitleLargeTextBlockStyle}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Wersja 1.0.0" HorizontalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                   Text="Aplikacja do pobierania faktur zakupowych z Krajowego Systemu e-Fakturowania (KSeF), filtrowania po NIP dostawców, eksportu do PDF i generowania raportów Excel."/>
        <HyperlinkButton Content="Dokumentacja KSeF API"
                         NavigateUri="https://api.ksef.mf.gov.pl/docs/v2"
                         HorizontalAlignment="Center"/>
        <TextBlock Text="© 2026 | Dane uwierzytelniające szyfrowane przez DPAPI (Windows)"
                   HorizontalAlignment="Center"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    </StackPanel>
</Page>

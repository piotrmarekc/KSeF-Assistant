<Page
    x:Class="KSeFAssistant.UI.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="32">
        <StackPanel MaxWidth="600" Spacing="16">

            <TextBlock Text="Ustawienia połączenia z KSeF"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,8"/>

            <!-- Środowisko -->
            <TextBlock Text="Środowisko KSeF" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <ComboBox x:Name="EnvironmentCombo"
                      SelectionChanged="EnvironmentCombo_SelectionChanged"
                      HorizontalAlignment="Stretch"/>

            <!-- NIP -->
            <TextBlock Text="NIP firmy (10 cyfr)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="NipBox"
                     PlaceholderText="np. 1234567890"
                     Text="{Binding Nip, Mode=TwoWay}"
                     MaxLength="10"
                     InputScope="Number"/>

            <!-- Metoda autoryzacji -->
            <TextBlock Text="Metoda autoryzacji" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <ComboBox x:Name="AuthMethodCombo"
                      SelectionChanged="AuthMethodCombo_SelectionChanged"
                      HorizontalAlignment="Stretch"/>

            <!-- Panel TOKEN -->
            <StackPanel Visibility="{Binding IsTokenMode, Converter={StaticResource BoolToVisibility}}"
                        Spacing="8">
                <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                         Message="Token API generujesz w module MCU (ksef.podatki.gov.pl). Ważny do 31.12.2026."/>
                <TextBlock Text="Token API" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <PasswordBox x:Name="TokenBox"
                             PlaceholderText="Wklej token API"
                             Password="{Binding ApiToken, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Panel CERTYFIKAT -->
            <StackPanel Visibility="{Binding IsTokenMode, Converter={StaticResource BoolToVisibilityInverse}}"
                        Spacing="8">
                <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                         Message="Certyfikaty X.509 (.pfx) pobierasz z modułu MCU. Obowiązkowe od 01.01.2027."/>
                <TextBlock Text="Plik certyfikatu (.pfx)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CertPathBox"
                             Grid.Column="0"
                             PlaceholderText="Ścieżka do pliku .pfx"
                             Text="{Binding CertificatePath}"
                             IsReadOnly="True"/>
                    <Button Grid.Column="1" Content="Przeglądaj..."
                            Click="BrowseCertificate_Click"/>
                </Grid>
                <TextBlock Text="Hasło certyfikatu" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <PasswordBox x:Name="CertPasswordBox"
                             PlaceholderText="Hasło do pliku .pfx"
                             Password="{Binding CertificatePassword, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Przyciski -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Zapisz ustawienia"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding SaveSettingsCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverse}}"/>
                <Button Content="Testuj połączenie"
                        Command="{Binding TestConnectionCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverse}}"/>
                <ProgressRing IsActive="{Binding IsBusy}"
                              Width="24" Height="24"/>
            </StackPanel>

            <!-- Status -->
            <InfoBar x:Name="StatusBar"
                     IsOpen="{Binding StatusMessage, Converter={StaticResource StringToBool}}"
                     Severity="{Binding IsStatusSuccess, Converter={StaticResource BoolToSeverity}}"
                     Message="{Binding StatusMessage}"
                     IsClosable="False"/>

        </StackPanel>
    </ScrollViewer>
</Page>

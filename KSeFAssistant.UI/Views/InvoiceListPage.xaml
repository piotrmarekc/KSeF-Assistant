<Page
    x:Class="KSeFAssistant.UI.Views.InvoiceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =============================================================== -->
        <!-- LEWY PANEL — filtry -->
        <!-- =============================================================== -->
        <ScrollViewer Grid.Column="0"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,1,0"
                      Padding="16">
            <StackPanel Spacing="12">

                <TextBlock Text="Filtry" Style="{StaticResource SubtitleTextBlockStyle}"/>

                <!-- Rok -->
                <TextBlock Text="Rok" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="YearCombo"
                          SelectionChanged="YearCombo_SelectionChanged"
                          HorizontalAlignment="Stretch"/>

                <!-- Miesiąc -->
                <TextBlock Text="Miesiąc" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="MonthCombo"
                          SelectionChanged="MonthCombo_SelectionChanged"
                          HorizontalAlignment="Stretch"/>

                <!-- Przycisk pobierania -->
                <Button Content="Pobierz faktury"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding FetchInvoicesCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverse}}"
                        HorizontalAlignment="Stretch"/>

                <Button Content="Anuluj"
                        Command="{Binding CancelFetchCommand}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Filtry NIP -->
                <TextBlock Text="Dostawcy" Style="{StaticResource BodyStrongTextBlockStyle}"
                           Visibility="{Binding SupplierFilters.Count, Converter={StaticResource IntToVisibility}}"/>

                <ItemsControl ItemsSource="{Binding SupplierFilters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,2">
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Zastosuj filtr NIP"
                        Command="{Binding ApplyNipFilterCommand}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding SupplierFilters.Count, Converter={StaticResource IntToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- =============================================================== -->
        <!-- PRAWY PANEL — lista faktur -->
        <!-- =============================================================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pasek akcji -->
            <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Background="Transparent">
                <AppBarButton Icon="SelectAll" Label="Zaznacz wszystkie"
                              Command="{Binding SelectAllCommand}"/>
                <AppBarButton Icon="ClearSelection" Label="Odznacz wszystkie"
                              Command="{Binding DeselectAllCommand}"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Download" Label="Eksportuj zaznaczone"
                              Click="ExportSelected_Click"
                              IsEnabled="{Binding SelectedCount, Converter={StaticResource IntToBool}}"/>
                <AppBarButton Icon="SaveLocal" Label="Pobierz PDF z KSeF"
                              Click="DownloadPdfFromKSeF_Click"
                              IsEnabled="{Binding SelectedCount, Converter={StaticResource IntToBool}}"/>
                <AppBarButton Icon="Stop" Label="Anuluj pobieranie"
                              Click="CancelPdfDownload_Click"
                              Visibility="{Binding IsPdfDownloading, Converter={StaticResource BoolToVisibility}}"/>
            </CommandBar>

            <!-- Pasek postępu -->
            <ProgressBar Grid.Row="1"
                         Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMax}"
                         Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibility}}"
                         IsIndeterminate="{Binding ProgressMax, Converter={StaticResource IntToBoolInverse}}"/>

            <!-- DataGrid faktur -->
            <toolkit:DataGrid
                Grid.Row="2"
                x:Name="InvoiceGrid"
                ItemsSource="{Binding DisplayedInvoices}"
                AutoGenerateColumns="False"
                IsReadOnly="False"
                CanUserSortColumns="True"
                CanUserReorderColumns="True"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="{ThemeResource SubtleFillColorSecondaryBrush}"
                Margin="0,4,0,0">

                <toolkit:DataGrid.Columns>
                    <!-- Checkbox zaznaczenia -->
                    <toolkit:DataGridCheckBoxColumn
                        Binding="{Binding IsSelected, Mode=TwoWay}"
                        Width="40"
                        CanUserReorder="False"
                        CanUserSort="False"/>

                    <toolkit:DataGridTextColumn
                        Header="Nr faktury"
                        Binding="{Binding InvoiceNumber}"
                        Width="150"/>

                    <toolkit:DataGridTextColumn
                        Header="Data"
                        Binding="{Binding IssueDate}"
                        Width="90"/>

                    <toolkit:DataGridTextColumn
                        Header="NIP dostawcy"
                        Binding="{Binding SellerNip}"
                        Width="110"/>

                    <toolkit:DataGridTextColumn
                        Header="Nazwa dostawcy"
                        Binding="{Binding SellerName}"
                        Width="200"/>

                    <toolkit:DataGridTextColumn
                        Header="Netto"
                        Binding="{Binding TotalNetValue, Converter={StaticResource DecimalFormatter}}"
                        Width="100"/>

                    <toolkit:DataGridTextColumn
                        Header="VAT"
                        Binding="{Binding VatTotal, Converter={StaticResource DecimalFormatter}}"
                        Width="90"/>

                    <toolkit:DataGridTextColumn
                        Header="Brutto"
                        Binding="{Binding TotalGrossValue, Converter={StaticResource DecimalFormatter}}"
                        Width="100"/>

                    <toolkit:DataGridTextColumn
                        Header="Waluta"
                        Binding="{Binding Currency}"
                        Width="60"/>

                    <toolkit:DataGridTextColumn
                        Header="Nr KSeF"
                        Binding="{Binding KSeFNumber}"
                        Width="200"/>
                </toolkit:DataGrid.Columns>
            </toolkit:DataGrid>

            <!-- Pasek statusu -->
            <Border Grid.Row="3"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Zaznaczono: " Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedCount}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text=" | Łącznie: " Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="InvoiceCountBlock" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

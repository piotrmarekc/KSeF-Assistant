<Page
    x:Class="KSeFAssistant.UI.Views.InvoiceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:KSeFAssistant.UI.ViewModels"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =============================================================== -->
        <!-- LEWY PANEL — filtry -->
        <!-- =============================================================== -->
        <ScrollViewer Grid.Column="0"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,1,0"
                      Padding="16">
            <StackPanel Spacing="12">

                <TextBlock Text="Filtry" Style="{StaticResource SubtitleTextBlockStyle}"/>

                <!-- Rok -->
                <TextBlock Text="Rok" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.Years}"
                          SelectedItem="{x:Bind ViewModel.SelectedYear, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>

                <!-- Miesiąc -->
                <TextBlock Text="Miesiąc" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="MonthCombo"
                          ItemsSource="{x:Bind ViewModel.MonthNames}"
                          SelectedIndex="{x:Bind ViewModel.SelectedMonth, Mode=TwoWay, Converter={StaticResource MonthIndexConverter}}"
                          HorizontalAlignment="Stretch"/>

                <!-- Przycisk pobierania -->
                <Button Content="Pobierz faktury"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.FetchInvoicesCommand}"
                        HorizontalAlignment="Stretch"/>

                <Button Content="Anuluj"
                        Command="{x:Bind ViewModel.CancelFetchCommand}"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Filtry NIP -->
                <TextBlock Text="Dostawcy" Style="{StaticResource BodyStrongTextBlockStyle}"
                           Visibility="{x:Bind ViewModel.SupplierFilters.Count, Mode=OneWay,
                                        Converter={StaticResource IntToVisibility}}"/>

                <ItemsControl ItemsSource="{x:Bind ViewModel.SupplierFilters, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SupplierFilterItem">
                            <CheckBox Content="{x:Bind DisplayText}"
                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      TextWrapping="Wrap"
                                      Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Zastosuj filtr NIP"
                        Command="{x:Bind ViewModel.ApplyNipFilterCommand}"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.SupplierFilters.Count, Mode=OneWay,
                                     Converter={StaticResource IntToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- =============================================================== -->
        <!-- PRAWY PANEL — lista faktur -->
        <!-- =============================================================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pasek akcji -->
            <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Background="Transparent">
                <AppBarButton Icon="SelectAll" Label="Zaznacz wszystkie"
                              Command="{x:Bind ViewModel.SelectAllCommand}"/>
                <AppBarButton Icon="ClearSelection" Label="Odznacz wszystkie"
                              Command="{x:Bind ViewModel.DeselectAllCommand}"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Download" Label="Eksportuj zaznaczone"
                              Click="ExportSelected_Click"
                              IsEnabled="{x:Bind ViewModel.SelectedCount, Mode=OneWay,
                                         Converter={StaticResource IntToBool}}"/>
            </CommandBar>

            <!-- Pasek postępu -->
            <ProgressBar Grid.Row="1"
                         Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                         Maximum="{x:Bind ViewModel.ProgressMax, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay,
                                      Converter={StaticResource BoolToVisibility}}"
                         IsIndeterminate="{x:Bind ViewModel.ProgressMax, Mode=OneWay,
                                           Converter={StaticResource IntToBoolInverse}}"/>

            <!-- DataGrid faktur -->
            <toolkit:DataGrid
                Grid.Row="2"
                x:Name="InvoiceGrid"
                ItemsSource="{x:Bind ViewModel.DisplayedInvoices, Mode=OneWay}"
                AutoGenerateColumns="False"
                IsReadOnly="False"
                CanUserSortColumns="True"
                CanUserReorderColumns="True"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="{ThemeResource SubtleFillColorSecondaryBrush}"
                Margin="0,4,0,0">

                <toolkit:DataGrid.Columns>
                    <!-- Checkbox zaznaczenia -->
                    <toolkit:DataGridCheckBoxColumn
                        Binding="{Binding IsSelected, Mode=TwoWay}"
                        Width="40"
                        CanUserReorder="False"
                        CanUserSort="False"/>

                    <toolkit:DataGridTextColumn
                        Header="Nr faktury"
                        Binding="{Binding InvoiceNumber}"
                        Width="150"/>

                    <toolkit:DataGridTextColumn
                        Header="Data"
                        Binding="{Binding IssueDate}"
                        Width="90"/>

                    <toolkit:DataGridTextColumn
                        Header="NIP dostawcy"
                        Binding="{Binding SellerNip}"
                        Width="110"/>

                    <toolkit:DataGridTextColumn
                        Header="Nazwa dostawcy"
                        Binding="{Binding SellerName}"
                        Width="200"/>

                    <toolkit:DataGridTextColumn
                        Header="Netto"
                        Binding="{Binding TotalNetValue, Converter={StaticResource DecimalFormatter}}"
                        Width="100"/>

                    <toolkit:DataGridTextColumn
                        Header="VAT"
                        Binding="{Binding VatTotal, Converter={StaticResource DecimalFormatter}}"
                        Width="90"/>

                    <toolkit:DataGridTextColumn
                        Header="Brutto"
                        Binding="{Binding TotalGrossValue, Converter={StaticResource DecimalFormatter}}"
                        Width="100"/>

                    <toolkit:DataGridTextColumn
                        Header="Waluta"
                        Binding="{Binding Currency}"
                        Width="60"/>

                    <toolkit:DataGridTextColumn
                        Header="Nr KSeF"
                        Binding="{Binding KSeFNumber}"
                        Width="200"/>
                </toolkit:DataGrid.Columns>
            </toolkit:DataGrid>

            <!-- Pasek statusu -->
            <Border Grid.Row="3"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                        <Run Text="Zaznaczono: "/>
                        <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}"/>
                        <Run Text=" | Łącznie: "/>
                        <Run Text="{x:Bind ViewModel.DisplayedInvoices.Count, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
